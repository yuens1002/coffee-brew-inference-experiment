{
  "name": "coffee-brew-inference-experiment",
  "version": "2.0.3",
  "description": "Coffee brew inference experiment with Hono, TypeScript, and MCP",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "npx tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@hono/mcp": "^0.1.1",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.8.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@prisma/client": "^5.22.0",
    "dotenv": "^17.3.1",
    "hono": "^4.7.5",
    "hono-rate-limiter": "^0.5.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.13",
    "prisma": "^5.22.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
